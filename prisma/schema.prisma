generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String           @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  githubUrl        String?
  linkedInUrl      String?
  portfolioUrl     String?
  dateOfBirth      DateTime?
  phone            String?
  clerkId          String           @unique
  role             UserRole         @default(USER)
  profileCompleted Boolean          @default(false)
  location         String?
  education        Education[]
  experiences      Experience[]
  createdBy        Job[]
  applications     JobApplication[]
  resumes          Resume[]
  skills           Skill[]
}

model Job {
  id             String           @unique @default(cuid())
  title          String
  company        String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  status         JobStatus
  createdById    String
  description    String
  employmentType EmploymentType
  experienceMax  Int?
  experienceMin  Int?
  location       String?
  salaryMax      Int?
  salaryMin      Int?
  createdBy      User             @relation(fields: [createdById], references: [id])
  application    JobApplication[]

  @@index([status])
  @@index([createdById])
}

model Education {
  id                  String                 @id @default(cuid())
  college             String
  userId              String
  degree              String
  cgpa                Float
  isCurrentlyStudying Boolean                @default(false)
  startDate           DateTime
  endDate             DateTime?
  createdAt           DateTime               @default(now())
  applications        ApplicationEducation[]
  user                User                   @relation(fields: [userId], references: [id])

  @@unique([userId, college, degree, startDate])
  @@index([userId])
}

model ApplicationEducation {
  id            String         @id @default(cuid())
  applicationId String
  educationId   String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  education     Education      @relation(fields: [educationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, educationId])
}

model Experience {
  id           String                  @id @default(cuid())
  userId       String
  company      String
  role         String
  startDate    DateTime
  endDate      DateTime?
  description  String
  createdAt    DateTime                @default(now())
  applications ApplicationExperience[]
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, company, startDate, role])
  @@index([userId])
}

model ApplicationExperience {
  id            String         @id @default(cuid())
  applicationId String
  experienceId  String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  experience    Experience     @relation(fields: [experienceId], references: [id], onDelete: Cascade)
}

model Skill {
  id           String             @id @default(cuid())
  userId       String
  name         String             @unique
  createdAt    DateTime           @default(now())
  applications ApplicationSkill[]
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model ApplicationSkill {
  id            String         @id @default(cuid())
  applicationId String
  skillId       String
  application   JobApplication @relation(fields: [applicationId], references: [id])
  skill         Skill          @relation(fields: [skillId], references: [id])

  @@unique([applicationId, skillId])
}

model Resume {
  id           String           @id @default(cuid())
  userId       String
  fileName     String
  fileUrl      String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]
  user         User             @relation(fields: [userId], references: [id])

  @@index([userId])
}

model JobApplication {
  id                  String                  @id @default(cuid())
  userId              String
  jobId               String
  currentStep         Int                     @default(1)
  isSubmitted         Boolean                 @default(false)
  submittedAt         DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  githubUrl           String?
  linkedInUrl         String?
  portfolioUrl        String?
  resumeId            String?
  selectedEducations  ApplicationEducation[]
  selectedExperiences ApplicationExperience[]
  selectedSkills      ApplicationSkill[]
  job                 Job                     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume              Resume?                 @relation(fields: [resumeId], references: [id])
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([jobId])
  @@index([userId])
}

enum UserRole {
  USER
  ADMIN
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}
